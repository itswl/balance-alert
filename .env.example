# ========================================
# 余额告警系统 - 环境变量配置模板
# ========================================
# 复制此文件为 .env 并填入真实值
#
# 使用方法：
# 1. cp .env.example .env
# 2. 编辑 .env 填入真实的密钥和密码

# ========================================
# 系统设置
# ========================================
BALANCE_REFRESH_INTERVAL_SECONDS=3600
MAX_CONCURRENT_CHECKS=5
ALERT_COOLDOWN_SECONDS=86400
SUBSCRIPTION_ALERT_COOLDOWN_SECONDS=86400

# ========================================
# 数据持久化配置
# ========================================
# 是否启用数据库持久化（默认启用）
ENABLE_DATABASE=true

# 数据库 URL 配置
# 格式: <数据库类型>://<用户名>:<密码>@<主机>:<端口>/<数据库名>[?参数]
#
# SQLite (本地文件数据库，默认配置):
DATABASE_URL=sqlite:///./data/balance_alert.db
#
# PostgreSQL (推荐用于生产环境):
# DATABASE_URL=postgresql://username:password@localhost:5432/balance_alert
#
# PostgreSQL with SSL:
# DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
#
# MySQL (适合 Web 应用):
# 注意：必须使用 mysql+pymysql:// 前缀
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/balance_alert?charset=utf8mb4
#
# MySQL with SSL:
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname?charset=utf8mb4&ssl=true
#
# 云服务示例:
# PostgreSQL:
#   AWS RDS:      postgresql://user:pass@xxx.rds.amazonaws.com:5432/balance_alert?sslmode=require
#   Supabase:     postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Railway/Render: 平台会自动提供 DATABASE_URL 环境变量
# MySQL:
#   AWS RDS:      mysql+pymysql://admin:pass@xxx.rds.amazonaws.com:3306/balance_alert?charset=utf8mb4
#   阿里云 RDS:    mysql+pymysql://user:pass@rm-xxxxx.mysql.rds.aliyuncs.com:3306/balance_alert?charset=utf8mb4
#   腾讯云 CDB:    mysql+pymysql://user:pass@cdb-xxxxx.sql.tencentcdb.com:3306/balance_alert?charset=utf8mb4
#
# 配置助手:
#   PostgreSQL: ./scripts/setup_postgresql.sh
#   MySQL:      ./scripts/setup_mysql.sh

# ========================================
# Webhook 告警配置
# ========================================
WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN
WEBHOOK_SOURCE=credit-monitor
WEBHOOK_TYPE=feishu

# Grafana 监控栈密码（启用 docker compose --profile monitoring 时必填）
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password

# ========================================
# 邮箱配置
# ========================================
EMAIL_PASSWORD=your-email-password

# ========================================
# 项目监控配置
# ========================================
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
UNIAPI_API_KEY=uniapi-your-key
WXRANK_API_KEY=your-wxrank-api-key
VOLC_1_API_KEY=AKLT_YOUR_ACCESS_KEY:YOUR_SECRET_KEY_BASE64
VOLC_2_API_KEY=AKLT_YOUR_ACCESS_KEY:YOUR_SECRET_KEY_BASE64
ALIYUN_1_API_KEY=YOUR_ACCESS_KEY_ID:YOUR_ACCESS_KEY_SECRET
ALIYUN_2_API_KEY=YOUR_ACCESS_KEY_ID:YOUR_ACCESS_KEY_SECRET
TIKHUB_API_KEY=your-tikhub-api-key

# ========================================
# 订阅续费提醒配置
# ========================================
# 订阅建议在 Web UI 中维护（持久化到数据库），或写入 config.json 并使用占位符引用

# ========================================
# Web 服务器配置（可选）
# ========================================
WEB_PORT=8080
WEB_HOST=0.0.0.0
WEB_ENABLE_CORS=false
WEB_API_KEY=change-me  # 访问 Web/API 的认证密钥

# ========================================
# 日志配置（可选）
# ========================================
# LOG_LEVEL=INFO
# LOG_FILE=logs/balance_alert.log

# ========================================
# Prometheus 监控配置（可选）
# ========================================
# PROMETHEUS_PORT=9100
# PROMETHEUS_METRICS_PATH=/metrics
