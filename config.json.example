{
  "settings": {
    "balance_refresh_interval_seconds": 3600,
    "max_concurrent_checks": 5
  },
  "webhook": {
    "_comment": "推荐使用环境变量占位符（不存在则保留原样）",
    "url": "${WEBHOOK_URL}",
    "source": "${WEBHOOK_SOURCE}",
    "type": "${WEBHOOK_TYPE}"
  },
  "email": [],
  "subscriptions": [],
  "projects": [
    {
      "name": "OpenRouter",
      "owner_project": "AI 平台",
      "provider": "openrouter",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${OPENROUTER_API_KEY}",
      "threshold": 10000.0,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "UniAPI",
      "owner_project": "AI 平台",
      "provider": "uniapi",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${UNIAPI_API_KEY}",
      "threshold": 5000.0,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "WxRank-微信公众号",
      "owner_project": "增长工具",
      "provider": "wxrank",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${WXRANK_API_KEY}",
      "threshold": 500,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "Volc-火山引擎-自然选择",
      "owner_project": "云服务",
      "provider": "volc",
      "_comment": "AK:SK（用冒号分隔）",
      "api_key": "${VOLC_1_API_KEY}",
      "threshold": 7000,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Volc-火山引擎-陌玉",
      "owner_project": "云服务",
      "provider": "volc",
      "_comment": "AK:SK（用冒号分隔）",
      "api_key": "${VOLC_2_API_KEY}",
      "threshold": 1000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Aliyun-阿里云-1",
      "owner_project": "云服务",
      "provider": "aliyun",
      "_comment": "KeyId:Secret（用冒号分隔）",
      "api_key": "${ALIYUN_1_API_KEY}",
      "threshold": 10000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Aliyun-阿里云-2",
      "owner_project": "云服务",
      "provider": "aliyun",
      "_comment": "KeyId:Secret（用冒号分隔）",
      "api_key": "${ALIYUN_2_API_KEY}",
      "threshold": 100000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "TikHub",
      "owner_project": "数据服务",
      "provider": "tikhub",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${TIKHUB_API_KEY}",
      "threshold": 10.0,
      "type": "balance",
      "enabled": true
    }
  ]
}
