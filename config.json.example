{
  "settings": {
    "balance_refresh_interval_seconds": 3600,
    "max_concurrent_checks": 5,
    "min_refresh_interval_seconds": 60,
    "enable_smart_refresh": false,
    "smart_refresh_threshold_percent": 5
  },
  "webhook": {
    "_comment": "推荐使用环境变量占位符（不存在则保留原样）",
    "url": "${WEBHOOK_URL}",
    "source": "${WEBHOOK_SOURCE}",
    "type": "${WEBHOOK_TYPE}"
  },
  "email": [
    {
      "name": "邮箱",
      "host": "imap.example.com",
      "port": 993,
      "username": "user@example.com",
      "_comment": "密码建议只放在环境变量中",
      "password": "${EMAIL_PASSWORD}",
      "use_ssl": true,
      "enabled": true
    }
  ],
  "subscriptions": [
    {
      "name": "emqx - mqtt - 授权",
      "owner_project": "AI 平台",
      "cycle_type": "monthly",
      "renewal_day": 9,
      "alert_days_before": 3,
      "amount": 0,
      "currency": "USD",
      "enabled": true
    },
    {
      "name": "融云 - im - 授权",
      "owner_project": "云服务",
      "cycle_type": "monthly",
      "renewal_day": 17,
      "alert_days_before": 3,
      "amount": 3500.0,
      "currency": "CNY",
      "last_renewed_date": "2026-01-15",
      "enabled": true
    },
    {
      "name": "GitHub Copilot",
      "owner_project": "AI 平台",
      "cycle_type": "yearly",
      "renewal_day": 101,
      "alert_days_before": 7,
      "amount": 100.0,
      "currency": "USD",
      "last_renewed_date": "2026-01-01",
      "enabled": true
    },
    {
      "name": "每周备份服务",
      "owner_project": "数据服务",
      "cycle_type": "weekly",
      "renewal_day": 1,
      "alert_days_before": 1,
      "amount": 50.0,
      "currency": "CNY",
      "enabled": true
    }
  ],
  "projects": [
    {
      "name": "OpenRouter",
      "owner_project": "AI 平台",
      "provider": "openrouter",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${OPENROUTER_API_KEY}",
      "threshold": 10000.0,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "UniAPI",
      "owner_project": "AI 平台",
      "provider": "uniapi",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${UNIAPI_API_KEY}",
      "threshold": 5000.0,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "WxRank-微信公众号",
      "owner_project": "增长工具",
      "provider": "wxrank",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${WXRANK_API_KEY}",
      "threshold": 500,
      "type": "credits",
      "enabled": true
    },
    {
      "name": "Volc-火山引擎-自然选择",
      "owner_project": "云服务",
      "provider": "volc",
      "_comment": "AK:SK（用冒号分隔）",
      "api_key": "${VOLC_1_API_KEY}",
      "threshold": 7000,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Volc-火山引擎-陌玉",
      "owner_project": "云服务",
      "provider": "volc",
      "_comment": "AK:SK（用冒号分隔）",
      "api_key": "${VOLC_2_API_KEY}",
      "threshold": 1000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Aliyun-阿里云-1",
      "owner_project": "云服务",
      "provider": "aliyun",
      "_comment": "KeyId:Secret（用冒号分隔）",
      "api_key": "${ALIYUN_1_API_KEY}",
      "threshold": 10000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "Aliyun-阿里云-2",
      "owner_project": "云服务",
      "provider": "aliyun",
      "_comment": "KeyId:Secret（用冒号分隔）",
      "api_key": "${ALIYUN_2_API_KEY}",
      "threshold": 100000.0,
      "type": "balance",
      "enabled": true
    },
    {
      "name": "TikHub",
      "owner_project": "数据服务",
      "provider": "tikhub",
      "_comment": "API Key 建议只放在环境变量中",
      "api_key": "${TIKHUB_API_KEY}",
      "threshold": 10.0,
      "type": "balance",
      "enabled": true
    }
  ]
}
